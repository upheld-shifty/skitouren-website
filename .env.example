# Copy to .env and fill in values before running docker compose up

# PostgreSQL
POSTGRES_PASSWORD=changeme_strong_password

# Admin credentials
ADMIN_USERNAME=admin

# BCrypt hash MUST be in single quotes — otherwise Docker Compose expands the $ signs
# in the hash and corrupts it. Generate hash with cost 12:
#   docker run --rm node:22-alpine node -e \
#     "require('bcryptjs').hash('deinPasswort',12).then(h=>console.log(\"'\"+h+\"'\"))"
# Or use: https://bcrypt-generator.com (cost 12), then wrap in single quotes manually
ADMIN_PASSWORD_HASH='$2a$12$REPLACE_WITH_YOUR_BCRYPT_HASH'

# JWT secret — generate with: openssl rand -hex 32
# Also in single quotes to be safe
JWT_SECRET='REPLACE_WITH_64_HEX_CHARS_FROM_OPENSSL_RAND_HEX_32'
